<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- This app does not track users across apps or websites. -->
    <key>NSPrivacyTracking</key>
    <false/>
    <key>NSPrivacyTrackingDomains</key>
    <array/>
    <!-- This app does not collect any data for the developer. It is a local
         extension host that forwards mail events to the user's own machine. -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>
    <!-- No required-reason APIs are used in the container app. -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array/>
</dict>
</plist>
