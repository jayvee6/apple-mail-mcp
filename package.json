{
  "name": "@jdot6/apple-mail-mcp",
  "version": "1.1.0",
  "description": "The only way to give Claude (or any LLM) access to Apple Mail and iCloud — local AppleScript bridge for macOS",
  "main": "dist/index.js",
  "bin": {
    "apple-mail-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "skill/"
  ],
  "mcpName": "io.github.jayvee6/apple-mail-mcp",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
